  "file_scan_exclusions": ["**/node_modules"],
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager",
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "agent": {
    "play_sound_when_agent_done": true,
    "notify_when_agent_waiting": "all_screens",
    "favorite_models": [
      {
        "provider": "LocalLiteLLM",
        "model": "cometapi/gpt-5.1-codex",
      },
      {
        "provider": "LocalLiteLLM",
        "model": "cometapi/claude-sonnet-4-5",
      },
      {
        "provider": "LocalLiteLLM",
        "model": "cometapi/qwen3-coder",
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5-mini",
      },
      {
        "provider": "copilot_chat",
        "model": "gemini-3-flash-preview",
      },
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.2",
      },
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.5",
      },
      {
        "provider": "copilot_chat",
        "model": "gemini-3-pro-preview",
      },
    ],
    "profiles": {
      "custom-1": {
        "name": "Custom1",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "always_allow_tool_actions": true,
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "grok-code-fast-1",
    },
    "commit_message_model": {
      "provider": "copilot_chat",
      "model": "grok-code-fast-1",
    },
    "inline_alternatives": [
      { "provider": "comet", "model": "qwen3-coder-plus" },
      { "provider": "comet", "model": "gpt-5.1" },
    ],
  },
  "title_bar": {
    "show_branch_icon": true,
  },
  "theme": "Dawnfox - opaque",
  "vim_mode": true,
  "ui_font_size": 14,
  "ui_font_family": "Hack",
  "buffer_font_size": 14,
  // "buffer_font_family": "Hack",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "terminal": {
    "font_size": 14,
    "font_family": "JetBrainsMono Nerd Font",
    "dock": "right",
  },
  "relative_line_numbers": "enabled",
  "wrap_guides": [80, 120],
  "soft_wrap": "editor_width",
  "inlay_hints": {
    // "enabled": true
    "enabled": true,
  },
  "indent_guides": {
    "coloring": "indent_aware",
    "line_width": 2,
  },
  "format_on_save": "on",
  "project_panel": {
    "indent_size": 10,
    "auto_fold_dirs": true,
  },
  "languages": {
    "TSX": {
      "show_edit_predictions": true,
    },
    "YAML": {
      "tab_size": 2,
    },
    "Python": {
      "format_on_save": "on",
      "language_servers": ["pyright", "ruff"],
      "formatter": [
        {
          "language_server": {
            "name": "ruff",
          },
        },
        { "external": { "command": "ruff", "arguments": ["format", "-"] } },
      ],
    },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "tsserver": {
          "maxTsServerMemory": 16184,
        },
        "vtsls": {
          "experimental": {
            "maxInlayHintLength": 30,
          },
        },
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
        },
      },
    },
  },
}
